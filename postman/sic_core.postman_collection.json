{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-000000000001",
    "name": "SIC API",
    "description": "Implementation of accounting system based in hordak and following SIC (Andrisani) definitions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "{{baseUrl}}"
    }
  ],
  "item": [
    {
      "name": "Utility",
      "item": [
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/ping",
            "description": "Returns pong. Use as a lightweight availability check."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\"message\": \"pong\"}"
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Liveness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/healthz"
          },
          "response": []
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/readyz"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "Create Item",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Request-ID", "value": "{{$guid}}", "description": "Optional client-supplied request ID" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Widget\",\n  \"description\": \"A useful widget.\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Item",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/items/{{itemId}}",
            "header": [
              { "key": "X-Request-ID", "value": "{{$guid}}" }
            ]
          },
          "response": []
        }
      ]
    }
  ]
}
