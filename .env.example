# Copy to .env and fill in values before running locally.
# Never commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=@qUUwZMC07hBh__DJANGO_SECRET_KEY__404aTm#HbUfcgtj__DJANGO_SECRET_KEY__zrUqWB%Q4lWOKhranF@X
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sic_core

# ── Redis (optional) ──────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# In production, set REDIS_URL to a shared cache endpoint.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_WORKER_CLASS=sync
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=2

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=sic_core

# ── CORS (optional) ───────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=http://localhost:3000
