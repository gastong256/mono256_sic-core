# Copy to .env and fill in values before running locally.
# Never commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=@qUUwZMC07hBh__DJANGO_SECRET_KEY__404aTm#HbUfcgtj__DJANGO_SECRET_KEY__zrUqWB%Q4lWOKhranF@X
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sic_core
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=true
DB_CONNECT_TIMEOUT=5

# ── Redis (optional) ──────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# In production, set REDIS_URL to a shared cache endpoint.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=2
GUNICORN_WORKER_CLASS=sync
GUNICORN_THREADS=1
GUNICORN_TIMEOUT=30
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=2
GUNICORN_ACCESS_LOG=false

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=sic_core
REQUEST_LOG_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=1000
REQUEST_LOG_SKIP_PATHS=/healthz,/readyz
ACCOUNT_CHART_CACHE_TIMEOUT=300
ACCOUNT_VISIBILITY_CACHE_TIMEOUT=300
REGISTRATION_CONFIG_CACHE_TIMEOUT=300
TENANT_ALLOWED_IDS=
AUTH_REGISTER_THROTTLE_RATE=6/min
AUTH_TOKEN_OBTAIN_THROTTLE_RATE=12/min
AUTH_TOKEN_REFRESH_THROTTLE_RATE=30/min

# ── Production Security (override on prod env) ───────────────────────────────
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_REFERRER_POLICY=same-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_HOST=true
USE_X_FORWARDED_PROTO=true
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
ENABLE_ADMIN_SITE=true
ENABLE_API_DOCS=true
ENABLE_EXAMPLE_API=true

# ── Migrations/bootstrap ──────────────────────────────────────────────────────
# If true, run startup migration/bootstrap tasks from run_gunicorn.sh.
# Useful on platforms without pre-deploy commands (for example, Render Free).
RUN_MIGRATIONS_ON_START=true
# Django migrate verbosity (0 silences non-critical migration output).
MIGRATE_VERBOSITY=1
# One-time bootstrap admin creation (set true for one deploy, then false).
CREATE_SUPERUSER_ON_START=false
# Required when CREATE_SUPERUSER_ON_START=true.
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=
# If true, run_migrations.sh also loads the base chart command after migrate.
# Preferred name for startup/deploy platforms (Render, etc.).
LOAD_CHART_ON_START=false
# If true, run_migrations.sh runs collectstatic in pre-deploy.
COLLECTSTATIC_ON_MIGRATE=true

# ── CORS (optional) ───────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=http://localhost:3000
